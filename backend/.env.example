# ==============================================================================
# KrishiSaarthi Backend – Environment Configuration
# ==============================================================================
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.
# ==============================================================================

# ── Django Core ──────────────────────────────────────────────────────────────
DJANGO_SECRET_KEY=change-me-to-a-random-64-char-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# ── Database ─────────────────────────────────────────────────────────────────
# Leave empty for local SQLite; set for PostgreSQL in production:
# DATABASE_URL=postgresql://krishiuser:strongpassword@localhost:5432/krishisaarthi
DATABASE_URL=

# ── Redis / Celery ───────────────────────────────────────────────────────────
REDIS_URL=redis://127.0.0.1:6379/0

# ── Third-Party API Keys ────────────────────────────────────────────────────
# Get at: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=
# Get at: https://openweathermap.org/api
OPENWEATHER_API_KEY=

# ── Google Earth Engine ──────────────────────────────────────────────────────
# Path to a GCP service-account JSON with Earth Engine scope:
GOOGLE_APPLICATION_CREDENTIALS=
# GEE project ID (used in ee.Initialize):
GEE_PROJECT=

# ── CORS ─────────────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5000,http://localhost:3000

# ── Email (production only) ─────────────────────────────────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=

# ── Frontend URL (used in password-reset emails) ────────────────────────────
FRONTEND_URL=http://localhost:5173

# ── Admin Superuser (used by init_db.py) ────────────────────────────────────
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=admin@krishisaarthi.com
DJANGO_SUPERUSER_PASSWORD=

# ── Production Security ─────────────────────────────────────────────────────
SECURE_SSL_REDIRECT=False

# ── Docker / PostgreSQL ─────────────────────────────────────────────────────
POSTGRES_DB=krishisaarthi
POSTGRES_USER=krishiuser
POSTGRES_PASSWORD=
DB_NAME=krishisaarthi
DB_USER=krishiuser
DB_PASSWORD=
REDIS_PASSWORD=

# ── Monitoring ───────────────────────────────────────────────────────────────
GRAFANA_PASSWORD=admin
