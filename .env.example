# ============================================================
# KrishiSaarthi — Environment Variables
# ============================================================
# Copy this file to .env and fill in the values.
# Required variables are marked with [REQUIRED].
# ============================================================

# ── Django ───────────────────────────────────────────────────
DJANGO_SECRET_KEY=your-secret-key-here           # [REQUIRED] Generate with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DEBUG=True                                        # Set to False in production
ALLOWED_HOSTS=localhost,127.0.0.1                 # Comma-separated list of allowed hosts

# ── Database ─────────────────────────────────────────────────
# Leave empty to use SQLite (development). Set for PostgreSQL (production).
DATABASE_URL=                                     # e.g. postgresql://user:pass@localhost:5432/krishisaarthi

# Docker Compose PostgreSQL
POSTGRES_DB=krishisaarthi
POSTGRES_USER=krishiuser
POSTGRES_PASSWORD=changeme                        # [REQUIRED for Docker] Change in production

# ── Redis / Celery ───────────────────────────────────────────
REDIS_URL=redis://127.0.0.1:6379/0               # Redis connection URL
REDIS_PASSWORD=changeme                           # [REQUIRED for Docker prod]

# ── API Keys ─────────────────────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key                # [REQUIRED] Google Gemini AI (chat, soil, irrigation, pest validation)
OPENWEATHER_API_KEY=your-openweather-api-key      # [REQUIRED] OpenWeatherMap API key
GOOGLE_APPLICATION_CREDENTIALS=path/to/service-account.json  # [REQUIRED] Google Earth Engine service account

# ── CORS ─────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5000,http://localhost:3000

# ── Frontend ─────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173                # Used for password reset email links
VITE_API_BASE_URL=http://localhost:8000           # Frontend → Backend API base URL

# ── Email (production only) ──────────────────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password

# ── Production Security ──────────────────────────────────────
SECURE_SSL_REDIRECT=False                         # Set True if behind SSL termination

# ── Monitoring ───────────────────────────────────────────────
GRAFANA_PASSWORD=admin                            # [REQUIRED for Docker prod] Grafana admin password
